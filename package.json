{
  "name": "decky-task-manager",
  "version": "0.0.1",
  "description": "A lightweight Decky panel for plugin log errors, system metrics, and disabling plugins.",
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "pnpm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuri/decky-task-manager.git"
  },
  "keywords": [
    "decky",
    "plugin",
    "task-manager",
    "logs",
    "metrics",
    "steam-deck",
    "deck"
  ],
  "author": "yuri",
  "bugs": {
    "url": "https://github.com/yuri/decky-task-manager/issues"
  },
  "homepage": "https://github.com/yuri/decky-task-manager#readme",
  "devDependencies": {
    "@decky/rollup": "^1.0.2",
    "@decky/ui": "^4.11.0",
    "@rollup/rollup-linux-x64-musl": "^4.53.3",
    "@types/react": "19.1.1",
    "@types/react-dom": "19.1.1",
    "@types/webpack": "^5.28.5",
    "rollup": "^4.53.3",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "@decky/api": "^1.1.3",
    "react-icons": "^5.3.0",
    "tslib": "^2.7.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "react",
        "react-dom"
      ]
    }
  }
}
